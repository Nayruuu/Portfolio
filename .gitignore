# skill-creator eval scaffolding (snapshots, run outputs, benchmarks) — never commit
/.claude/skills/*-workspace/
.DS_Store

# reproducibility proof workspace (generated; see REPRODUCIBILITY.md + .claude/scripts/)
/repro/
reproduction-score.json

# transient marker: kit changed this iteration (mark-kit-dirty → stop-docs)
.claude/.kit-dirty

# Infra (Terraform) — state, provider cache, lock file, CI-generated tfvars.
infra/**/.terraform/
infra/**/.terraform.lock.hcl
infra/**/*.tfstate
infra/**/*.tfstate.*
infra/**/terraform.tfvars.json

# WASM prototype (explored + dropped; has node_modules) — local only
/client/wasm-proto/
# Asset-generation prompts (local working notes)
/prompts/
