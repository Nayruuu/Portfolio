{
  "name": "super-dev-portfolio",
  "version": "1.0.0",
  "description": "Portfolio in Angular 21 — full-stack .NET / Angular / Azure dev",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "gen:og": "node scripts/gen-og.mjs",
    "gen:icons": "node scripts/gen-icons.mjs",
    "gen:seo": "node scripts/gen-seo.mjs",
    "gen:article-bodies": "node scripts/gen-article-bodies.mjs",
    "i18n": "node scripts/gen-i18n.mjs",
    "build:ssg": "ng build --configuration production && npm run gen:seo && node scripts/check-prerender.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:watch": "ng test --watch",
    "test:cov": "ng test --coverage && node scripts/check-core-coverage.mjs",
    "e2e": "playwright test",
    "e2e:update": "playwright test --update-snapshots",
    "format": "prettier --write \"src/**/*.{ts,html,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,json}\"",
    "lint": "eslint . && stylelint \"src/**/*.scss\"",
    "lint:fix": "eslint . --fix && stylelint \"src/**/*.scss\" --fix",
    "lint:style": "stylelint \"src/**/*.scss\"",
    "optimize:game-art": "node scripts/optimize-game-art.mjs"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-server": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/ssr": "^21.2.13",
    "@ngrx/signals": "^21.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.6.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.17.19",
    "@vitest/coverage-v8": "^4.1.7",
    "angular-eslint": "^21.4.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "sharp": "^0.35.2",
    "stylelint": "^17.12.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  }
}
